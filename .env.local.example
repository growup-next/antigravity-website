# Google AI Studio から取得: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Pinecone ダッシュボードから取得: https://app.pinecone.io/
PINECONE_API_KEY=
# 例: zerog-web-kb
PINECONE_INDEX_NAME=
# 省略可能。未設定時は "zerog-web"
PINECONE_NAMESPACE=zerog-web
# 省略可能。埋め込みの次元数（Pinecone インデックスと一致させること / デフォルト 768）
PINECONE_EMBEDDING_DIMENSIONS=768
